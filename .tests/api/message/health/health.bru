meta {
  name: Message health check
  type: http
  seq: 1
}

get {
  url: {{messageBaseUrl}}/health
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.status: eq ok
  res.body.service: eq points-mall-message
  res.body.db: eq ok
  res.body.timestamp: isDefined
  res.body.uptime: isDefined
}
