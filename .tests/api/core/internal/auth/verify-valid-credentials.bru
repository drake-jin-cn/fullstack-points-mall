meta {
  name: Verify employee - valid credentials
  type: http
  seq: 1
}

post {
  url: {{coreBaseUrl}}/internal/auth/verify
  body: json
  auth: none
}

headers {
  INTERNAL_API_KEY: {{coreInternalApiKey}}
}

body:json {
  {
    "email": "alice@pointsmall.com",
    "password": "Alice@123456"
  }
}

assert {
  res.status: eq 200
  res.body.code: eq OK
  res.body.data.email: eq alice@pointsmall.com
  res.body.data.isActive: eq true
  res.body.data.roles: isDefined
  res.body.traceId: isUndefined
}
