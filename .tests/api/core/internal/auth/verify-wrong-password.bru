meta {
  name: Verify employee - wrong password
  type: http
  seq: 2
}

post {
  url: {{coreBaseUrl}}/internal/auth/verify
  body: json
  auth: none
}

headers {
  INTERNAL_API_KEY: {{coreInternalApiKey}}
}

body:json {
  {
    "email": "alice@pointsmall.com",
    "password": "WrongPassword"
  }
}

assert {
  res.status: eq 401
  res.body.code: eq core-1001
  res.body.traceId: isDefined
}
