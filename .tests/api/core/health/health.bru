meta {
  name: Core health check
  type: http
  seq: 1
}

get {
  url: {{coreBaseUrl}}/health
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.status: eq ok
  res.body.service: eq points-mall-core
  res.body.db: isDefined
  res.body.timestamp: isDefined
  res.body.uptime: isDefined
}
