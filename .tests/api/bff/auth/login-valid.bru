meta {
  name: BFF login - valid credentials
  type: http
  seq: 1
}

post {
  url: {{bffBaseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "admin@pointsmall.com",
    "password": "Admin@123456"
  }
}

assert {
  res.status: eq 200
  res.body.code: eq OK
  res.body.data.user.email: eq admin@pointsmall.com
  res.body.data.user.roles: isDefined
  res.headers["set-cookie"]: isDefined
}
