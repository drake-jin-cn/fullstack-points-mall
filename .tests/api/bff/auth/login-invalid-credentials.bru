meta {
  name: BFF login - invalid credentials
  type: http
  seq: 2
}

post {
  url: {{bffBaseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "admin@pointsmall.com",
    "password": "WrongPassword"
  }
}

assert {
  res.status: eq 401
  res.body.code: eq bff-2001
  res.body.traceId: isDefined
  res.body.data: isNull
}
