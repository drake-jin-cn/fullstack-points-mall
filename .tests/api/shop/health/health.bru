meta {
  name: Shop health check
  type: http
  seq: 1
}

get {
  url: {{shopBaseUrl}}/api/health
  body: none
  auth: none
}

assert {
  res.status: eq 200
  res.body.status: eq ok
  res.body.service: eq points-mall-shop
  res.body.db: isDefined
  res.body.timestamp: isDefined
  res.body.uptime: isDefined
}
